# Database
DB_URL=postgresql://bot_user:bot_password@db:5432/auto_applier

# AI
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram (configure after creating the bot with @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Chrome path on the HOST machine (for LinkedIn via Nodriver)
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Daily application limits
MAX_APPLICATIONS_PER_DAY_LINKEDIN=5
MAX_APPLICATIONS_PER_DAY_COMPUTRABAJO=15
MAX_APPLICATIONS_PER_DAY_INDEED=15

# Gmail email monitor (optional)
# Use an App Password, NOT your regular Gmail password.
# Generate one at: myaccount.google.com/apppasswords
# IMAP must be enabled in Gmail Settings → See all settings → Forwarding and POP/IMAP
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
